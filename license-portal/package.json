{
  "name": "safesweep-license-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit",
    "preflight:prod": "node scripts/preflight-prod.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "backup:db": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/backup-db.ps1",
    "backup:db:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/backup-db-prod.ps1",
    "decrypt:db:backup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/decrypt-db-backup.ps1",
    "restore:db": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/restore-db.ps1",
    "admin:create": "tsx scripts/create-admin.ts",
    "stripe:webhook": "stripe listen --forward-to localhost:3000/api/stripe/webhook"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "bcryptjs": "^3.0.2",
    "jose": "^6.0.11",
    "lucide-react": "^0.475.0",
    "next": "^15.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^18.2.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.31",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.5",
    "prisma": "^6.10.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
