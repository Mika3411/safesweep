DATABASE_URL="postgresql://safesweep:safesweep@localhost:5432/safesweep_portal?schema=public"
AUTH_SECRET="change-me-at-least-32-random-characters"
LICENSE_HASH_SECRET="change-me-another-32-random-characters"
LICENSE_KEY_ENCRYPTION_SECRET="change-me-32-random-characters-for-one-time-license-delivery"
LICENSE_API_SECRET="shared-secret-used-by-the-desktop-software"
# Required in production for distributed rate limiting.
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="upstash-rest-token"
TRUSTED_PROXY_IPS="127.0.0.1,10.0.0.0/8"
CSRF_TRUSTED_ORIGINS="http://localhost:3000"
APP_URL="http://localhost:3000"
SOFTWARE_DOWNLOAD_URL="https://downloads.example.com/safesweep/latest"

# Stripe Billing
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_default_fallback"
STRIPE_ENDPOINT_PRICE_ID="price_endpoint_subscription"
STRIPE_SERVER_PRICE_ID="price_server_subscription"
STRIPE_MOBILE_PRICE_ID="price_mobile_subscription"

# Transactional emails via Resend
RESEND_API_KEY="re_..."
EMAIL_FROM="SafeSweep <licences@example.com>"
EMAIL_REPLY_TO="support@example.com"
RESEND_API_URL="https://api.resend.com/emails"

# PostgreSQL production backups
BACKUP_ENCRYPTION_KEY="replace-with-at-least-32-random-characters"
BACKUP_COMPRESSION_LEVEL="9"
BACKUP_UPLOAD_ENABLED="false"
BACKUP_S3_BUCKET="safesweep-db-backups"
BACKUP_S3_PREFIX="license-portal/postgresql"
BACKUP_S3_ENDPOINT_URL=""
AWS_REGION="eu-west-3"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
